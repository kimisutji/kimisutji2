<Window x:Class="Aldar21.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aldar21 Tracker" Height="450" Width="700">

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        

        <ListBox x:Name="SubjectsList"
                 Grid.Column="0"
                 FontSize="16"/>


        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Фильтр" FontWeight="Bold"/>

            <Button Content="Все"
                    Click="FilterAll_Click"
                    Margin="0,5"/>

            <Button Content="Сдано"
                    Click="FilterDone_Click"
                    Margin="0,5"/>

            <Button Content="Не сдано"
                    Click="FilterNotDone_Click"
                    Margin="0,5"/>

            <Separator Margin="10"/>

            <TextBlock Text="Название дисциплины"/>

            <TextBox x:Name="SubjectNameBox"
                     Margin="0,5"/>

            <CheckBox x:Name="SubjectStatus"
                      Content="Сдано"
                      Margin="0,5"/>

            <Button Content="Добавить"
                    Click="Add_Click"
                    Margin="0,5"/>

            <Button Content="Удалить"
                    Click="Delete_Click"
                    Margin="0,5"/>

            <Button Content="Изменить статус"
                    Click="ChangeStatus_Click"
                    Margin="0,5"/>

            <Separator Margin="10"/>

            <Button Content="Сохранить файл"
                    Click="Save_Click"
                    Margin="0,5"/>

        </StackPanel>

    </Grid>
</Window>